---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-[--theme-border-soft] py-12">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-4">
    <a href="#hero" class="flex items-center gap-3">
      <span class="text-lg font-bold tracking-[0.2em] uppercase text-[--theme-ink]">DG</span>
      <span class="w-px h-5 bg-[--theme-border]" aria-hidden="true"></span>
      <span class="text-sm font-light tracking-[0.2em] uppercase text-[--theme-ink-secondary]">Integral</span>
    </a>

    <p class="text-sm text-[--theme-ink-muted] text-center md:text-right">
      &copy; {currentYear} DG Integral Consultora. Todos los derechos reservados.
    </p>
  </div>
</footer>
