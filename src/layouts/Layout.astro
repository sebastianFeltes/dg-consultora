---
import "../styles/global.css";
import ogImageSrc from "../assets/dg-consultora-no-text.png";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "DG Integral Consultoría | Soluciones Estratégicas Globales",
  description = "Consultoría integral para el crecimiento de su organización.",
} = Astro.props;

// URL absoluta de la página (para og:url)
const canonicalURL = new URL(
  Astro.url.pathname,
  "https://sebastianFeltes.github.io"
).href;

// URL absoluta de la imagen OG
// ogImageSrc.src ya incluye el base path, ej: /dg-consultora/_astro/dg-consultora-no-text.HASH.png
const ogImage = new URL(ogImageSrc.src, "https://sebastianFeltes.github.io").href;

const siteName = "DG Integral Consultoría";
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Favicon -->
    <!-- <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} /> -->
    <link rel="icon" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.ico`} />

    <meta name="generator" content={Astro.generator} />

    <!-- SEO básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- ── Open Graph (Facebook, WhatsApp, LinkedIn, Telegram) ── -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content={String(ogImageSrc.width)} />
    <meta property="og:image:height" content={String(ogImageSrc.height)} />
    <meta property="og:image:alt" content={siteName} />
    <meta property="og:locale" content="es_AR" />

    <!-- ── Twitter / X Card ── -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={siteName} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      (function () {
        var theme = localStorage.getItem("theme");
        if (!theme) {
          theme = window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }
        if (theme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
